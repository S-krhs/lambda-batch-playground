{
	"name": "@lambda-batch-playground/batch-playground",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"clean": "rm -rf dist",
		"build": "npm run clean && tsc -p tsconfig.json",
		"local": "node --loader ts-node/esm src/local-runner.ts",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "biome ci src docs package.json tsconfig.json",
		"validate": "npm run typecheck && npm run lint"
	},
	"dependencies": {
		"@lambda-batch-playground/integration-discord": "0.1.0",
		"@lambda-batch-playground/libs": "0.1.0",
		"dotenv": "^17.4.2"
	},
	"devDependencies": {
		"ts-node": "^10.9.2"
	}
}
