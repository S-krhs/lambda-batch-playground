{
	"name": "eskra-aws-playground",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "npm@11.8.0",
	"workspaces": [
		"apps/*",
		"infra",
		"packages/integrations/*",
		"packages/libs/*",
		"repositories"
	],
	"scripts": {
		"postinstall": "prisma generate",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate deploy",
		"db:migrate:dev": "prisma migrate dev",
		"build": "turbo run build",
		"build:browser-runtime-layer": "node infra/layers/browser-runtime/build.mjs",
		"deploy": "npm run build && npm run build:browser-runtime-layer && sst deploy --stage develop --config infra/sst.config.ts",
		"local:deps": "turbo run build --filter=@eskra-aws-playground/batch-playground^... --filter=@eskra-aws-playground/batch-anime-analysis^...",
		"local:batch-playground": "npm run local:deps && npm --workspace @eskra-aws-playground/batch-playground run local",
		"local:batch-anime-analysis": "npm run local:deps && npm --workspace @eskra-aws-playground/batch-anime-analysis run local",
		"test": "turbo run test -- --exclude '**/dist/**'",
		"test:ci": "turbo run test --continue -- --exclude '**/dist/**' --reporter=default --reporter=json --outputFile.json=vitest-report.json",
		"test:summary": "node scripts/ci-test-summary.js",
		"typecheck": "turbo run typecheck",
		"lint": "biome ci . && turbo run lint",
		"format": "biome format .",
		"format:fix": "biome format --write .",
		"validate": "npm run typecheck && npm run lint && npm run test"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@types/node": "^26.1.0",
		"prisma": "^7.8.0",
		"prisma-zod-generator": "^2.1.4",
		"sst": "^4.17.0",
		"turbo": "^2.6.1",
		"typescript": "^5.5.4",
		"vitest": "^4.1.9"
	}
}
