generator client {
  provider            = "prisma-client"
  output              = "../repositories/generated/prisma"
  importFileExtension = "js"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../repositories/generated/zod"
}

datasource db {
  provider = "postgresql"
  schemas  = ["anime", "playground"]
}

model ScrapingMetric {
  id           BigInt   @id @default(autoincrement())
  /// @zod.string.min(1)
  dataSourceId String   @map("data_source_id")
  /// @zod.string.min(1)
  label        String
  /// @zod.number.finite()
  value        Float
  scrapedDate  DateTime @map("scraped_date") @db.Date
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([dataSourceId, scrapedDate])
  @@map("scraping_metrics")
  @@schema("anime")
}

model DiscordGuildSetting {
  applicationKey String   @map("application_key") @db.VarChar(64)
  guildId        String   @map("guild_id") @db.VarChar(20)
  settingKey     String   @map("setting_key") @db.VarChar(64)
  configuration  Json     @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@id([applicationKey, guildId, settingKey])
  @@map("discord_guild_settings")
  @@schema("playground")
}

model DiscordUserSetting {
  applicationKey String   @map("application_key") @db.VarChar(64)
  guildId        String   @map("guild_id") @db.VarChar(20)
  userId         String   @map("user_id") @db.VarChar(20)
  settingKey     String   @map("setting_key") @db.VarChar(64)
  configuration  Json     @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@id([applicationKey, guildId, userId, settingKey])
  @@index([applicationKey, settingKey])
  @@map("discord_user_settings")
  @@schema("playground")
}
