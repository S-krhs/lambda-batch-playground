{
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": ["**/*", "!**/package-lock.json", "!repositories/generated"]
	},
	"linter": {
		"rules": {
			"style": {
				"useConsistentArrowReturn": {
					"level": "error",
					"options": {
						"style": "always"
					}
				}
			}
		}
	}
}
