{
	"globalEnv": [
		"DEFAULT_DISCORD_WEBHOOK_URL",
		"UMA_ONE_DRAW_TOPIC_DISCORD_WEBHOOK_URL"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"test": {
			"dependsOn": ["^build"],
			"outputs": ["vitest-report.json"]
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"lint": {
			"outputs": []
		},
		"validate": {
			"dependsOn": ["typecheck", "lint", "test"],
			"outputs": []
		}
	}
}
