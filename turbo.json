{
	"globalEnv": [
		"DATABASE_URL",
		"DEFAULT_DISCORD_WEBHOOK_URL",
		"DIRECT_DATABASE_URL",
		"TEST_DATABASE_URL",
		"UMA_ONE_DRAW_TOPIC_DISCORD_WEBHOOK_URL",
		"UMA_ONE_DRAW_TOPIC_SCHEDULE_GROUP_NAME",
		"UMA_ONE_DRAW_TOPIC_SCHEDULER_ROLE_ARN",
		"UMA_ONE_DRAW_TOPIC_TARGET_FUNCTION_ARN"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"test": {
			"dependsOn": ["^build"]
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"lint": {
			"outputs": []
		},
		"validate": {
			"dependsOn": ["typecheck", "lint", "test"],
			"outputs": []
		}
	}
}
