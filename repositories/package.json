{
	"name": "@lambda-batch-playground/repositories",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		"./anime/*.test.js": null,
		"./anime/*.js": {
			"types": "./dist/anime/*.d.ts",
			"default": "./dist/anime/*.js"
		},
		"./playground/*.test.js": null,
		"./playground/*.js": {
			"types": "./dist/playground/*.d.ts",
			"default": "./dist/playground/*.js"
		}
	},
	"scripts": {
		"clean": "rm -rf dist",
		"build": "npm run clean && tsc -p tsconfig.json",
		"test": "vitest run",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "biome ci README.md anime playground package.json tsconfig.json",
		"validate": "npm run typecheck && npm run lint && npm run test"
	}
}
