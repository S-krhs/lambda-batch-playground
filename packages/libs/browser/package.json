{
	"name": "@eskra-aws-playground/libs-browser",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		"./html-scraper/chromium-browser.js": {
			"types": "./dist/html-scraper/chromium-browser.d.ts",
			"default": "./dist/html-scraper/chromium-browser.js"
		},
		"./html-scraper/webpage-html.js": {
			"types": "./dist/html-scraper/webpage-html.d.ts",
			"default": "./dist/html-scraper/webpage-html.js"
		}
	},
	"scripts": {
		"clean": "rm -rf dist",
		"build": "npm run clean && tsc -p tsconfig.json",
		"test": "vitest run",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "biome ci .",
		"validate": "npm run typecheck && npm run lint && npm run test"
	},
	"dependencies": {
		"@sparticuz/chromium": "149.0.0",
		"chromium-bidi": "15.0.0",
		"playwright-core": "1.61.1"
	}
}
